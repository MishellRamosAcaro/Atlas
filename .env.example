# =============================================================================
# Atlas – Backend API – Environment Example
# =============================================================================
# Copy to .env and fill values. Safe for Docker, CI/CD, local dev, and production.
# Never commit real secrets. This file is versioned as a template only.
# =============================================================================

# -----------------------------------------------------------------------------
# APP
# -----------------------------------------------------------------------------
# Runtime: dev (local, tests) | prod
ENV=dev

# Application name (for logs, headers; optional)
APP_NAME=Atlas

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Primary DB URL (async driver). Example: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/atlas

# Test DB URL for pytest (optional; used by CI and local test runs)
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/atlas_test


# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------
# Secret used to sign JWTs. MUST be changed in production; use a long random string.
JWT_SECRET_KEY=change-me-in-production-use-long-random-string

# Algorithm for JWT signing
JWT_ALGORITHM=HS256

# Access token lifetime in minutes
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh token lifetime in days
REFRESH_TOKEN_TTL_DAYS=7

# Max concurrent sessions per user (older sessions are removed)
MAX_SESSIONS_PER_USER=5

# Idle session expiry in days
IDLE_TIMEOUT_DAYS=30

# -----------------------------------------------------------------------------
# SECURITY – Login lockout (brute-force protection)
# -----------------------------------------------------------------------------
# Max failed login attempts before lockout
MAX_FAILED_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_MINUTES=15

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated allowed origins (e.g. https://app.example.com). Use * only in dev.
CORS_ORIGINS=http://localhost:8080


# -----------------------------------------------------------------------------
# COOKIES
# -----------------------------------------------------------------------------
# Domain for auth cookies (empty for same host; set in prod for subdomains)
COOKIE_DOMAIN=

# Use secure flag (true in production over HTTPS)
COOKIE_SECURE=false

# SameSite: lax | strict | none
COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# STORAGE / UPLOADS
# -----------------------------------------------------------------------------
# Local path for uploads in dev (e.g. ./data/uploads)
UPLOADS_STORAGE_PATH=./data/uploads

# GCS bucket name in production (optional; leave empty for local storage - FUTURE)
UPLOADS_GCS_BUCKET=

# Enable antivirus scanning for uploads (true in prod, false in dev without scanner )
UPLOADS_ANTIVIRUS_ENABLED=false

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------
# Resend API key for transactional email
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# EMAIL – Verification
# -----------------------------------------------------------------------------
# Verification code validity in minutes
VERIFICATION_CODE_TTL_MINUTES=15

# Max verification attempts per code
VERIFICATION_MAX_ATTEMPTS=5

# Cooldown before resend in minutes
VERIFICATION_RESEND_COOLDOWN_MINUTES=2

# Terms and privacy version strings (for consent tracking)
TERMS_VERSION=1.0
PRIVACY_VERSION=1.0

# -----------------------------------------------------------------------------
# FEATURE FLAGS / LLM (required – no defaults in code)
# -----------------------------------------------------------------------------
# One or more LLM presets (comma-separated). 
#Single: gemini-flash. 
#List:gemini-flash,claude-haiku,gpt-4o-mini,deepseek
LLM_PRESET=gemini-flash

# LLM tuning (required; all read from .env)
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192
LLM_TOP_P=1.0
LLM_TIMEOUT=120.0
LLM_MAX_RETRIES=1

# -----------------------------------------------------------------------------
# THIRD PARTY – LLM providers (set the one used by LLM_PRESET)
# -----------------------------------------------------------------------------
# Google AI (Gemini)
# GOOGLE_API_KEY=

# Anthropic (Claude)
# ANTHROPIC_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# OpenAI
# OPENAI_API_KEY=
