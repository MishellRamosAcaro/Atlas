# Database URLs
DATABASE_URL=
# For tests (pytest). Example: postgresql+asyncpg://postgres:postgres@localhost:5432/atlas_test
DATABASE_URL_TEST=

# JWT - MUST change in production
JWT_SECRET_KEY

# Environment: dev | prod
ENV=

# CORS - comma-separated origins in prod (e.g. https://app.example.com)
CORS_ORIGINS=

# Cookie - set COOKIE_SECURE=false for local HTTP dev
COOKIE_SECURE=

# Email verification (optional; defaults: 15 min TTL, 5 max attempts, 2 min resend cooldown)
# VERIFICATION_CODE_TTL_MINUTES=15
# VERIFICATION_MAX_ATTEMPTS=5
# VERIFICATION_RESEND_COOLDOWN_MINUTES=2
# TERMS_VERSION=1.0
# PRIVACY_VERSION=1.0

# DBeaver (optional)
DBEAVER_DEFAULT_EMAIL=
DBEAVER_DEFAULT_PASSWORD=
